# ── Venice AI ───────────────────────────────────────────────
VENICE_API_KEY=your_venice_api_key_here
VENICE_BASE_URL=https://api.venice.ai/api/v1

# ── Smart Contract ─────────────────────────────────────────
CONTRACT_ADDRESS=0x...deployed_APICredits_address...
RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

# ── Server ─────────────────────────────────────────────────
PORT=3001
# No model restrictions — users can request any model Venice supports

# ── Nullifier Storage ──────────────────────────────────────
# Default: in-memory (fine for dev, resets on restart)
NULLIFIER_STORE=memory
# For production, use Redis:
# NULLIFIER_STORE=redis://localhost:6379
